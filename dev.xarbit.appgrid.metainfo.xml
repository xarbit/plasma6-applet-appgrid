<component type="addon">
    <!--
        One component covers both shipped plasmoids: the centered desktop
        overlay (dev.xarbit.appgrid) and the panel popup
        (dev.xarbit.appgrid.panel). They are the same product in two form
        factors, so they share a single AppStream listing.
    -->
    <id>dev.xarbit.appgrid</id>
    <extends>org.kde.plasmashell</extends>
    <metadata_license>CC0-1.0</metadata_license>
    <project_license>GPL-2.0-or-later</project_license>

    <name>Application Launcher (modern)</name>
    <summary>A modern centered application grid launcher for KDE Plasma</summary>
    <description>
        <p>
            AppGrid is a modern centered application grid launcher for
            KDE Plasma. It provides a clean, visual way to browse and
            launch your applications.
        </p>
        <p>Features include:</p>
        <ul>
            <li>Two form factors: centered desktop overlay or native panel popup</li>
            <li>Centered grid overlay with Wayland layer-shell support</li>
            <li>Category-based filtering and KRunner search integration</li>
            <li>Quick commands: terminal, shell, file browser (type ? for help)</li>
            <li>Configurable icon size, grid dimensions, and sort order</li>
            <li>Pin to Task Manager, Add to Desktop, Favorites, Hide apps</li>
            <li>Session management (Sleep, Restart, Shut Down, Lock, Log Out)</li>
            <li>Background blur, opacity, and corner radius customization</li>
            <li>Alt+1 through Alt+9 shortcuts for instant search result launching</li>
            <li>New app detection and most-used sorting</li>
            <li>29 European language translations</li>
        </ul>
    </description>

    <url type="homepage">https://appgrid.xarbit.dev</url>
    <url type="bugtracker">https://github.com/xarbit/plasma6-applet-appgrid/issues</url>

    <developer id="dev.xarbit">
        <name>Jason Scurtu</name>
    </developer>

