msgid "Unhide All"
msgstr "Zobraziť všetko"

#: package/contents/ui/config/ConfigHiddenApps.qml:75
msgid ""
"Right-click any app in the grid to hide it, or type h: in the search bar."
msgstr ""
"Kliknite pravým tlačidlom na akúkoľvek aplikáciu v mriežke pre skrytie, "
"alebo napíšte h: do vyhľadávacieho poľa."

#: package/contents/ui/config/ConfigHiddenApps.qml:82
#| msgid "Hidden apps:"
msgid "Filter hidden apps…"
msgstr "Filtrovať skryté aplikácie…"

