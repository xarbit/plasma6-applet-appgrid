msgstr "Zobrazit vše"

#: package/contents/ui/config/ConfigHiddenApps.qml:75
msgid ""
"Right-click any app in the grid to hide it, or type h: in the search bar."
msgstr ""
"Klikněte pravým tlačítkem na jakoukoli aplikaci v mřížce pro skrytí, nebo "
"napište h: do vyhledávacího pole."

#: package/contents/ui/config/ConfigHiddenApps.qml:82
#| msgid "Hidden apps:"
msgid "Filter hidden apps…"
msgstr "Filtrovat skryté aplikace…"

