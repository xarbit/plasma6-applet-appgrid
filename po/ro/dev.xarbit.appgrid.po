#: package/contents/ui/config/ConfigAppearance.qml:174
msgid "Hide app grid until I start typing"
msgstr "Ascunde grila de aplicații până când încep să tastez"

#: package/contents/ui/config/ConfigAppearance.qml:181
msgid "Tip: press the Down arrow key to reveal the grid without typing."
msgstr "Sfat: apăsați tasta săgeată în jos pentru a afișa grila fără a tasta."

