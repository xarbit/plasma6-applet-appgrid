msgstr "衝擊"

#: package/contents/ui/config/ConfigAppearance.qml:215
msgid "Grow Up"
msgstr "向上放大"

#: package/contents/ui/config/ConfigAppearance.qml:221
msgid "Icon hover:"
msgstr "圖示停留效果："

#: package/contents/ui/config/ConfigAppearance.qml:224
msgid "Shake"
msgstr "搖晃"

#: package/contents/ui/config/ConfigAppearance.qml:225
msgid "Grow"
msgstr "放大"

#: package/contents/ui/config/ConfigAppearance.qml:226
msgid "Bounce"
msgstr "彈跳"

#: package/contents/ui/config/ConfigAppearance.qml:227
msgid "Spin"
msgstr "旋轉"

#: package/contents/ui/config/ConfigAppearance.qml:228
msgid "Shuffle"
msgstr "隨機"

#: package/contents/ui/config/ConfigAppearance.qml:234
msgid "Animate icons when the launcher opens"
msgstr "開啟時播放圖示動畫"

#: package/contents/ui/config/ConfigAppearance.qml:239
msgid "System:"
msgstr "系統："

#: package/contents/ui/config/ConfigAppearance.qml:240
msgid "Configure Animation Speed…"
msgstr "設定動畫速度…"

#: package/contents/ui/config/ConfigAppearance.qml:244
msgid ""
"Open KDE's animation settings to change the system-wide animation speed (the "
"slider that drives every Plasma animation, this launcher included)."
msgstr ""
"開啟 KDE 的動畫設定，以變更整個系統的動畫速度（控制每個 Plasma 動畫的滑桿；包含此啟動器）。"

#: package/contents/ui/config/ConfigGeneral.qml:50
msgid "Icon:"
