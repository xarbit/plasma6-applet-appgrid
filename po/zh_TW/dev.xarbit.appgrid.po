#: package/contents/ui/config/HeaderActionsConfig.qml:35
#: package/contents/ui/widgets/HeaderActionStrip.qml:47
msgid "Switch User"
msgstr "切換使用者"

#: package/contents/ui/config/HeaderActionsConfig.qml:39
msgid "Bar"
msgstr "工具列"

#: package/contents/ui/config/HeaderActionsConfig.qml:40
msgid "Menu"
msgstr "選單"

#: package/contents/ui/config/HeaderActionsConfig.qml:41
msgid "Off"
msgstr "停用"

