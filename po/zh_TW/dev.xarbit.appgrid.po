msgstr "滑動"

#: package/contents/ui/config/ConfigAppearance.qml:212
msgid "Buzz"
msgstr "振動"

#: package/contents/ui/config/ConfigAppearance.qml:213
msgid "Twist"
msgstr "扭轉"

#: package/contents/ui/config/ConfigAppearance.qml:214
