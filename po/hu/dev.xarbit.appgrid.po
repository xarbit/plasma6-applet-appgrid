msgid "Type a command to run in terminal"
msgstr "Írjon be egy parancsot a terminálban való futtatáshoz"

#: package/contents/ui/prefix/PrefixCommandView.qml:36
msgid "Type a command to execute"
msgstr "Írjon be egy parancsot a végrehajtáshoz"

#: package/contents/ui/prefix/PrefixCommandView.qml:38
