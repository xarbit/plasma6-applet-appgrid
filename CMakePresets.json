{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "release",
      "displayName": "Release",
      "description": "Optimised plasmoid build. Default for makepkg / dpkg-buildpackage / rpmbuild and what end users install.",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON",
        "CMAKE_INSTALL_PREFIX": "/usr"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Debuggable build with assertions. Use with gdb / kdbg.",
      "binaryDir": "${sourceDir}/build-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_INSTALL_PREFIX": "/usr"
      }
    },
    {
      "name": "tests",
      "displayName": "Tests",
      "description": "Release build with the C++ + QtQuickTest test suite. ctest runs under offscreen Qt.",
      "binaryDir": "${sourceDir}/build-tests",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "ON",
        "CMAKE_INSTALL_PREFIX": "/usr"
      }
    },
    {
      "name": "ci",
      "displayName": "CI gate",
      "description": "Tests + strict warnings (-Wall/-Wextra/-Werror). Matches the GitHub Actions Tests & Lint job.",
      "binaryDir": "${sourceDir}/build-ci",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "ON",
        "APPGRID_STRICT_WARNINGS": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_INSTALL_PREFIX": "/usr"
      }
    },
    {
      "name": "universal",
      "displayName": "Universal tarball",
      "description": "Release with the in-app update checker compiled in. Used by the universal tarball CI job — distros leave this OFF.",
      "binaryDir": "${sourceDir}/build-universal",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON",
        "APPGRID_UNIVERSAL_BUILD": "ON",
        "CMAKE_INSTALL_PREFIX": "/usr"
      }
    }
  ],
  "buildPresets": [
    { "name": "release",   "configurePreset": "release" },
    { "name": "debug",     "configurePreset": "debug" },
    { "name": "tests",     "configurePreset": "tests" },
    { "name": "ci",        "configurePreset": "ci" },
    { "name": "universal", "configurePreset": "universal" }
  ],
  "testPresets": [
    {
      "name": "tests",
      "configurePreset": "tests",
      "output": { "outputOnFailure": true },
      "environment": { "QT_QPA_PLATFORM": "offscreen" }
    },
    {
      "name": "ci",
      "configurePreset": "ci",
      "output": { "outputOnFailure": true },
      "environment": { "QT_QPA_PLATFORM": "offscreen" }
    }
  ]
}
