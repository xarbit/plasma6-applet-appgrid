#!/usr/bin/make -f
# SPDX-FileCopyrightText: 2026 AppGrid Contributors
# SPDX-License-Identifier: GPL-2.0-or-later
#
# debian/changelog is generated per Ubuntu series by CI — see
# .github/workflows/publish.yml. It is intentionally not committed.

# Upstream version = changelog version minus the ~<series> suffix CI
# appends for per-series uploads; '~' swapped back to '-' for the semver
# string the binary self-reports via APPGRID_VERSION_OVERRIDE.
APPGRID_VERSION := $(shell dpkg-parsechangelog -SVersion | sed 's/~[0-9.]*$$//; s/~/-/g')

%:
	dh $@ --buildsystem=cmake

override_dh_auto_configure:
	dh_auto_configure -- -DAPPGRID_VERSION_OVERRIDE=$(APPGRID_VERSION) -DBUILD_TESTING=OFF

# The unit tests are CI's job and need a Qt platform plugin; the Launchpad
# buildds are headless — skip the test step in the package build.
override_dh_auto_test:
